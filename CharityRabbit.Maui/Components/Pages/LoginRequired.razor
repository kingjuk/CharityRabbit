@inject CharityRabbit.Maui.Services.AuthService Auth
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="pa-6 mt-12">
    <MudPaper Elevation="4" Class="pa-8 text-center">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
        <MudText Typo="Typo.h5" GutterBottom="true">Sign in required</MudText>
        <MudText Typo="Typo.body1" Class="mb-6 mud-text-secondary">
            Sign in to track your volunteering, sign up for events, and earn carrots. 🥕
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Login" OnClick="LoginAsync" Disabled="_busy">
            @(_busy ? "Opening sign-in…" : "Sign In")
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    private bool _busy;

    private async Task LoginAsync()
    {
        _busy = true;
        try
        {
            var error = await Auth.LoginAsync();
            if (error is not null)
            {
                Snackbar.Add($"Sign-in failed: {error}", Severity.Error);
            }
        }
        finally
        {
            _busy = false;
        }
    }
}
